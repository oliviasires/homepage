<html>
sequence {
  position: absolute;
  bottom: 25%;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 20px;
  align-items: center;
}

.sequence img {
  width: 180px;
  border-radius: 12px;
  opacity: 0.9;
  transition: 0.3s ease;
}

.sequence img:hover {
  transform: scale(1.05);
  opacity: 1;
}
</html>
